@model IEnumerable<Layout.Models.SolicitudMovimiento>
@using Layout.Models.Enums

@{
    ViewData["Title"] = "Historial de Solicitudes";
}

<!-- Estilos adicionales integrados en el scope de la vista -->
<style>
    .text-truncate-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .dynamic-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        cursor: pointer;
    }

        .dynamic-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.1) !important;
        }

    .prevent-modal-trigger {
        position: relative;
        z-index: 2;
    }
</style>

<!-- Genera el token de seguridad necesario para las peticiones Fetch -->
@Html.AntiForgeryToken()

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-secondary mb-1">Peticiones Realizadas</h2>
            <p class="text-muted small mb-0">Listado completo de movimientos solicitados en el sistema</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>Nueva Solicitud
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center p-5 shadow-sm border-0" role="alert">
            <i class="bi bi-inbox fs-1 d-block mb-3 text-muted"></i>
            <h4 class="alert-heading fw-bold">No hay solicitudes registradas</h4>
            <p class="text-muted mb-0">Las peticiones que tú o tu equipo realicen aparecerán en este panel.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100 shadow-sm border-0 dynamic-card btn-detalle-solicitud"
                         data-id="@item.Id"
                         data-area="@(item.Area?.Nombre ?? "Sin Área")"
                         data-estatus="@item.Estatus.ToString()"
                         data-tipo="@item.TipoMovimiento.ToString()"
                         data-descripcion="@item.Descripcion"
                         data-razon="@item.Razon"
                         data-fecha="@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")"
                         data-imagen="@item.ImagenLayout"
                         data-aprobador="@(item.UsuarioAprobador?.UserName ?? "N/A")"
                         data-fecharevision="@(item.FechaRevision?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")"
                         data-comentarios="@(item.ComentariosRevision ?? "Sin comentarios adicionales")">

                        <div class="card-header bg-white border-bottom-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                            <span class="badge bg-light text-dark border px-2.5 py-1.5 fw-semibold">
                                <i class="bi bi-geo-alt me-1"></i>@(item.Area?.Nombre ?? "Sin Área")
                            </span>

                            @* SWITCH DE ESTADOS CON COLORES EN BADGES *@
                            @switch (item.Estatus)
                            {
                                case EstatusSolicitud.Pendiente:
                                    <span class="badge bg-warning text-dark px-2.5 py-1.5 fw-semibold">Pendiente</span>
                                    break;
                                case EstatusSolicitud.Aprobado:
                                case EstatusSolicitud.EnProceso:
                                    <span class="badge bg-info text-dark px-2.5 py-1.5 fw-semibold">En Proceso</span>
                                    break;
                                case EstatusSolicitud.Rechazado:
                                    <span class="badge bg-danger px-2.5 py-1.5 fw-semibold">Rechazada</span>
                                    break;
                                case EstatusSolicitud.Finalizado:
                                    <span class="badge bg-success px-2.5 py-1.5 fw-semibold">Finalizada</span>
                                    break;
                            }
                        </div>

                        <div class="card-body py-3">
                            <h5 class="card-title fw-bold text-primary mb-2">
                                @item.TipoMovimiento.ToString()
                            </h5>

                            <p class="card-text text-secondary text-truncate-3 small mb-3">
                                <strong>Descripción:</strong> @item.Descripcion
                            </p>

                            <p class="card-text text-muted text-truncate-2 small mb-0">
                                <strong>Justificación:</strong> @item.Razon
                            </p>
                        </div>

                        <div class="card-footer bg-light border-top-0 d-flex justify-content-between align-items-center py-2.5">
                            <small class="text-muted fw-medium">
                                <i class="bi bi-calendar3 me-1"></i>@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                            </small>

                            <div class="prevent-modal-trigger d-flex gap-2 align-items-center">
                                @* BOTÓN ESTANDARIZADO: VER LAYOUT *@
                                @if (!string.IsNullOrEmpty(item.ImagenLayout))
                                {
                                    <a href="@item.ImagenLayout" target="_blank" class="btn btn-sm btn-outline-secondary px-2.5 py-1 fw-semibold d-inline-flex align-items-center" title="Ver croquis adjunto" onclick="event.stopPropagation();">
                                        <i class="bi bi-image me-1"></i>Ver Layout
                                    </a>
                                }
                                else
                                {
                                    <span class="badge bg-white text-muted border px-2.5 py-1.5 small fw-normal italic">
                                        Sin Layout
                                    </span>
                                }

                                @* BOTÓN ESTANDARIZADO: COMPLETAR INFO *@
                                @if (item.Estatus == EstatusSolicitud.EnProceso || item.Estatus == EstatusSolicitud.Aprobado)
                                {
                                    <a asp-action="CompletarInventario"
                                       asp-controller="Solicitudes"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-primary px-2.5 py-1 shadow-sm fw-semibold d-inline-flex align-items-center"
                                       onclick="event.stopPropagation();"
                                       title="Llenar datos de inventario y movimientos técnicos">
                                        <i class="bi bi-pencil-square me-1"></i>Completar Info
                                    </a>
                                }
                                @* BADGE ESTANDARIZADO: PENDIENTE *@
                                else if (item.Estatus == EstatusSolicitud.Finalizado)
                                {
                                    <span class="badge bg-light text-secondary border px-2.5 py-1.5 small fw-semibold d-inline-flex align-items-center" title="Información técnica registrada con éxito">
                                        <i class="bi bi-clock-history me-1"></i>Completado
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- MODAL DE DETALLES DE LA SOLICITUD -->
<div class="modal fade" id="modalDetalle" tabindex="-1" aria-labelledby="modalDetalleLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">

            <!-- Encabezado del Modal -->
            <div class="modal-header bg-light border-bottom-0 py-3">
                <h5 class="modal-title fw-bold text-secondary" id="modalDetalleLabel">
                    <i class="bi bi-file-earmark-text me-2 text-primary"></i>Detalle de la Solicitud
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Cuerpo del Modal -->
            <div class="modal-body p-4">
                <div class="row g-3">

                    <!-- Datos Rápidos superiores -->
                    <div class="col-md-6">
                        <label class="text-uppercase text-muted fw-bold small d-block">Tipo de Movimiento</label>
                        <span id="modalTipo" class="fs-5 fw-bold text-primary"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="text-uppercase text-muted fw-bold small d-block">Área</label>
                        <span id="modalArea" class="badge bg-light text-dark border fs-6 px-2.5 py-1"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="text-uppercase text-muted fw-bold small d-block">Estatus</label>
                        <span id="modalEstatus" class="badge fs-6 px-2.5 py-1 fw-semibold"></span>
                    </div>

                    <hr class="my-3 text-muted opacity-25">

                    <!-- Descripción de la Solicitud -->
                    <div class="col-12">
                        <label class="text-uppercase text-muted fw-bold small d-block">Descripción</label>
                        <p id="modalDescripcion" class="text-secondary bg-light p-3 rounded border-start border-primary border-3"></p>
                    </div>

                    <!-- Justificación / Razón -->
                    <div class="col-12">
                        <label class="text-uppercase text-muted fw-bold small d-block">Justificación / Razón</label>
                        <p id="modalRazon" class="text-secondary bg-light p-3 rounded"></p>
                    </div>

                    <!-- Panel Informativo de Revisión (Aprobado / En Proceso / Finalizado / Rechazado) -->
                    <div id="seccionRevision" class="col-12 d-none">
                        <div class="card bg-light border-0 p-3 mt-2">
                            <h6 class="fw-bold text-secondary mb-3">
                                <i class="bi bi-shield-check me-2"></i>Información del Dictamen técnico
                            </h6>
                            <div class="row g-2 small">
                                <div class="col-sm-4">
                                    <strong>Dictaminó:</strong> <span id="modalAprobador"></span>
                                </div>
                                <div class="col-sm-4">
                                    <strong>Fecha de Dictamen:</strong> <span id="modalFechaRevision"></span>
                                </div>
                                <div class="col-12 mt-2">
                                    <strong>Comentarios del revisor:</strong>
                                    <p id="modalComentarios" class="mb-0 text-muted italic mt-1"></p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Visualización del Croquis Adjunto -->
                    <div id="seccionCroquis" class="col-12 text-center d-none">
                        <hr class="my-3 text-muted opacity-25">
                        <label class="text-uppercase text-muted fw-bold small d-block text-start mb-2">Layout Adjunto</label>
                        <img id="modalImagen" src=""
                             class="img-fluid rounded border shadow-sm"
                             style="max-height:250px; cursor:pointer;" />
                    </div>

                    <!-- Panel de Dictamen (Solo para peticiones en estado Pendiente) -->
                    <div id="seccionFormularioRevision" class="col-12 d-none">
                        <hr class="my-3 text-muted opacity-25">
                        <label class="text-uppercase text-danger fw-bold small d-block mb-2">Panel de Dictamen (Administrador)</label>
                        <textarea id="txtComentariosRevision" class="form-control" rows="2" placeholder="Escribe aquí los motivos de la aprobación o rechazo..."></textarea>
                    </div>
                </div>
            </div>

            <!-- PIE DEL MODAL CON BOTONES DE ACCIÓN -->
            <div class="modal-footer bg-light border-top-0 py-2.5">
                <small class="text-muted me-auto fw-medium">
                    <i class="bi bi-clock me-1"></i>Creado el: <span id="modalFecha"></span>
                </small>

                <!-- Botones para Administradores (Se muestran con JS si el estatus original es Pendiente) -->
                <div id="bloqueAccionesAdmin" class="d-none">
                    <button type="button" id="btnRechazar" class="btn btn-danger px-3 me-1 fw-semibold">
                        <i class="bi bi-x-circle me-1"></i>Rechazar
                    </button>
                    <button type="button" id="btnAprobar" class="btn btn-success px-3 me-3 fw-semibold">
                        <i class="bi bi-check-circle me-1"></i>Aprobar Movimiento
                    </button>
                </div>

                <button type="button" class="btn btn-secondary px-4 fw-semibold" data-bs-dismiss="modal">Cerrar</button>
            </div>

        </div>
    </div>
</div>

<!-- LIGHTBOX -->
<div id="imageLightbox" style="
    display:none;
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.85);
    z-index:9999;
    justify-content:center;
    align-items:center;
">

    <!-- Botón cerrar -->
    <span style="
        position:absolute;
        top:20px;
        right:30px;
        color:white;
        font-size:30px;
        cursor:pointer;
        z-index:10000;
    " onclick="document.getElementById('imageLightbox').style.display='none'">
        ✕
    </span>

    <img id="lightboxImg" style="
        max-width:90%;
        max-height:90%;
        border-radius:10px;
        box-shadow:0 0 20px rgba(0,0,0,0.5);
    " />
</div>


@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const modalElement = document.getElementById('modalDetalle');
            const bsModal = new bootstrap.Modal(modalElement);

            // ✅ Lightbox elementos (una sola vez)
            const lightbox = document.getElementById('imageLightbox');
            const lightboxImg = document.getElementById('lightboxImg');

            let solicitudIdActual = null;

            document.querySelectorAll('.btn-detalle-solicitud').forEach(card => {
                card.addEventListener('click', function () {

                    // 🔹 Datos
                    solicitudIdActual = this.getAttribute('data-id');
                    const area = this.getAttribute('data-area');
                    const estatus = this.getAttribute('data-estatus');
                    const tipo = this.getAttribute('data-tipo');
                    const descripcion = this.getAttribute('data-descripcion');
                    const razon = this.getAttribute('data-razon');
                    const fecha = this.getAttribute('data-fecha');
                    const imagen = this.getAttribute('data-imagen');
                    const aprobador = this.getAttribute('data-aprobador');
                    const fechaRevision = this.getAttribute('data-fecharevision');
                    const comentarios = this.getAttribute('data-comentarios');

                    // 🔹 Contenido
                    document.getElementById('modalTipo').innerText = tipo;
                    document.getElementById('modalArea').innerText = area;
                    document.getElementById('modalDescripcion').innerText = descripcion;
                    document.getElementById('modalRazon').innerText = razon;
                    document.getElementById('modalFecha').innerText = fecha;

                    // 🔹 Estatus
                    const badge = document.getElementById('modalEstatus');
                    badge.innerText = estatus;
                    badge.className = "badge fs-6 px-2.5 py-1";

                    if (estatus === "Pendiente") {
                        badge.classList.add("bg-warning", "text-dark");
                    } else if (estatus === "Aprobado") {
                        badge.classList.add("bg-success");
                    } else {
                        badge.classList.add("bg-danger");
                    }

                    // 🔹 Panel revisión
                    const seccionRevision = document.getElementById('seccionRevision');

                    if (estatus !== "Pendiente") {
                        document.getElementById('modalAprobador').innerText = aprobador;
                        document.getElementById('modalFechaRevision').innerText = fechaRevision;
                        document.getElementById('modalComentarios').innerText = comentarios;

                        seccionRevision.classList.remove('d-none');
                    } else {
                        seccionRevision.classList.add('d-none');
                    }

                    // 🔹 Panel admin
                    const bloqueAdmin = document.getElementById('bloqueAccionesAdmin');
                    const formRevision = document.getElementById('seccionFormularioRevision');

                    if (estatus === "Pendiente") {
                        bloqueAdmin.classList.remove('d-none');
                        formRevision.classList.remove('d-none');
                        document.getElementById('txtComentariosRevision').value = '';
                    } else {
                        bloqueAdmin.classList.add('d-none');
                        formRevision.classList.add('d-none');
                    }

                    // 🔹 Imagen + Lightbox
                    const seccionCroquis = document.getElementById('seccionCroquis');
                    const modalImagen = document.getElementById('modalImagen');

                    if (imagen && imagen.trim() !== "") {

                        modalImagen.src = imagen;

                        // ✅ click imagen → abrir lightbox
                        modalImagen.onclick = function (e) {
                            e.stopPropagation();
                            lightbox.style.display = "flex";
                            lightboxImg.src = this.src;
                        };

                        seccionCroquis.classList.remove('d-none');

                    } else {
                        seccionCroquis.classList.add('d-none');
                    }

                    bsModal.show();
                });
            });

            // ✅ cerrar lightbox
            lightbox.onclick = function () {
                lightbox.style.display = "none";
            };

            // 🔹 enviar dictamen
            async function enviarDictamen(nuevoEstatus) {

                const comentarios = document.getElementById('txtComentariosRevision').value;

                let estatusId = 0;
                if (nuevoEstatus === 'Aprobado') estatusId = 1;
                if (nuevoEstatus === 'Rechazado') estatusId = 2;

                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                const formData = new FormData();
                formData.append("id", solicitudIdActual);
                formData.append("nuevoEstatus", estatusId);
                formData.append("comentarios", comentarios);

                if (token) {
                    formData.append("__RequestVerificationToken", token);
                }

                try {
                    const response = await fetch('/Solicitudes/Evaluar', {
                        method: 'POST',
                        body: formData
                    });

                    if (!response.ok) {
                        throw new Error("Error servidor");
                    }

                    const result = await response.json();

                    if (result.success) {

                        if (result.redirectUrl) {
                            window.location.href = result.redirectUrl; // ✅ ir a formulario
                            return;
                        }

                        bsModal.hide();
                        window.location.reload();
                    }else {
                        alert(result.message);
                    }
                } catch (err) {
                    alert("Error procesando solicitud");
                    console.error(err);
                }
            }

            // ✅ botones
            document.getElementById('btnAprobar').addEventListener('click', () => enviarDictamen('Aprobado'));
            document.getElementById('btnRechazar').addEventListener('click', () => enviarDictamen('Rechazado'));

        });
    </script>
}

