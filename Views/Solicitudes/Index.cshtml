@model IEnumerable<Layout.Models.SolicitudMovimiento>
@using Layout.Models.Enums

@{
    ViewData["Title"] = "Historial de Solicitudes";
}

<!-- Estilos adicionales integrados en el scope de la vista -->
<style>

    /* Grid específico para los datos de inventario */
    .inventory-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 12px;
    }

    /* Celda individual de información técnica */
    .inventory-cell {
        background-color: #ffffff;
        border: 1px solid #eef1f6;
        border-radius: 12px;
        padding: 12px 14px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: all 0.2s ease;
    }

        .inventory-cell:hover {
            border-color: #d1dff8;
            background-color: #fafbfe;
        }

    /* Estilo para los textos internos de la celda */
    .inventory-cell-title {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #858796;
        margin-bottom: 6px;
    }

    .inventory-cell-value {
        font-size: 0.95rem;
        font-weight: 600;
        color: #3a3b45;
        word-break: break-word;
    }


    /* ==========================================================================
       ESTILOS AVANZADOS PARA TARJETAS MODERNAS Y TEXTO EN CARRUSEL
       ========================================================================== */

    /* Contenedor que restringe el texto a una sola línea con puntos suspensivos */
    .marquee-container {
        overflow: hidden;
        white-space: nowrap;
        position: relative;
        width: 100%;
    }

    .marquee-text {
        display: inline-block;
        padding-left: 0;
        text-overflow: ellipsis;
        overflow: hidden;
        width: 100%;
        transition: transform 0.1s linear;
    }

    /* Efecto carrusel horizontal fluido: se activa solo al pasar el cursor sobre la tarjeta */
    .dynamic-card:hover .marquee-text {
        overflow: visible;
        width: auto;
        animation: lateral-scroll 10s linear infinite;
    }

    @@keyframes lateral-scroll {
        0%

    {
        transform: translate3d(0, 0, 0);
    }

    100% {
        transform: translate3d(-50%, 0, 0);
    }

    }

    /* Diseño moderno de tarjetas con bordes redondeados y comportamiento suave */
    .dynamic-card {
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        cursor: pointer;
        border-radius: 14px !important;
        background: #ffffff;
    }

        .dynamic-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 20px rgba(0, 0, 0, 0.08) !important;
        }

    /* Sutil degradado superior para dar profundidad visual al encabezado */
    .card-header-gradient {
        background: linear-gradient(180deg, rgba(248,249,250,0.4) 0%, rgba(255,255,255,0) 100%);
        border-top-left-radius: 14px !important;
        border-top-right-radius: 14px !important;
    }

    /* Base limpia y consistente para el pie de la tarjeta */
    .card-footer-clean {
        background-color: #fcfcfc !important;
        border-bottom-left-radius: 14px !important;
        border-bottom-right-radius: 14px !important;
    }

    /* Evita que los botones y enlaces del pie activen por accidente el modal trasero */
    .prevent-modal-trigger {
        position: relative;
        z-index: 5;
    }

    /* Divisor estético entre las secciones internas del cuerpo */
    .divider-dashed {
        border-top: 1px dashed #e3e6f0;
        margin: 10px 0;
    }

    /* ==========================================================================
       ESTILOS AVANZADOS PARA EL MODAL PREMIUM
       ========================================================================== */

    /* Redondeado moderno y sombra suave para el contenedor del modal */
    #modalDetalle .modal-content {
        border-radius: 20px !important;
        overflow: hidden;
    }

    /* Encabezado con un sutil gradiente y tipografía limpia */
    #modalDetalle .modal-header {
        background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
        border-bottom: 1px solid rgba(0, 0, 0, 0.04) !important;
    }

    /* Estilo para los títulos de sección en mayúsculas pequeñas */
    #modalDetalle .modal-label-caps {
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: #6c757d;
        margin-bottom: 6px;
        display: block;
    }

    /* Bloques contenedores estilizados para la descripción y justificación */
    #modalDetalle .content-panel-box {
        background-color: #fcfcfc;
        border: 1px solid #f1f3f9;
        padding: 16px;
        border-radius: 12px;
        color: #495057;
        font-size: 0.95rem;
        line-height: 1.5;
    }

    /* Panel informativo del dictamen con un diseño de tarjeta integrada limpia */
    #modalDetalle .dictamen-card-info {
        background-color: #f4f7fe;
        border: 1px solid #e1e9f8;
        border-radius: 14px;
        padding: 18px;
    }

    /* Efecto hover suave para la imagen del layout adjunto */
    #modalDetalle .img-preview-layout {
        max-height: 280px;
        cursor: pointer;
        transition: all 0.3s ease;
        border: 1px solid #e3e6f0;
    }

        #modalDetalle .img-preview-layout:hover {
            transform: scale(1.02);
            box-shadow: 0 8px 20px rgba(0,0,0,0.1) !important;
        }

    /* Área de comentarios del administrador estilizada */
    #modalDetalle .textarea-dictamen {
        border-radius: 12px;
        padding: 12px;
        border: 1px solid #d1d3e2;
        transition: border-color 0.15s ease-in-out;
    }

        #modalDetalle .textarea-dictamen:focus {
            border-color: #4e73df;
            box-shadow: 0 0 0 0.2rem rgba(78,115,223,0.1);
        }

    /* Pie de página limpio */
    #modalDetalle .modal-footer {
        background-color: #fcfcfc;
        border-top: 1px solid rgba(0, 0, 0, 0.04) !important;
    }


</style>

<!-- Genera el token de seguridad necesario para las peticiones Fetch -->
@Html.AntiForgeryToken()

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-secondary mb-1">Peticiones Realizadas</h2>
            <p class="text-muted small mb-0">Listado completo de movimientos solicitados en el sistema</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm rounded-pill px-4">
            <i class="bi bi-plus-lg me-2"></i>Nueva Solicitud
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center p-5 shadow-sm border-0 rounded-4" role="alert">
            <i class="bi bi-inbox fs-1 d-block mb-3 text-muted"></i>
            <h4 class="alert-heading fw-bold">No hay solicitudes registradas</h4>
            <p class="text-muted mb-0">Las peticiones que tú o tu equipo realicen aparecerán en este panel.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100 shadow-sm border btn-detalle-solicitud dynamic-card"
                         data-id="@item.Id"
                         data-area="@(item.Area?.Nombre ?? "Sin Área")"
                         data-estatus="@item.Estatus.ToString()"
                         data-tipo="@item.TipoMovimiento.ToString()"
                         data-descripcion="@item.Descripcion"
                         data-razon="@item.Razon"
                         data-fecha="@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")"
                         data-imagen="@item.ImagenLayout"
                         data-aprobador="@(item.UsuarioAprobador?.UserName ?? "N/A")"
                         data-fecharevision="@(item.FechaRevision?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")"
                         data-comentarios="@(item.ComentariosRevision ?? "Sin comentarios adicionales")"
                         data-validacion="@item.InventarioTemporal?.NumeroValidacion"
                         data-responsable="@item.InventarioTemporal?.ResponsableInventario"
                         data-mandril="@item.InventarioTemporal?.MandrilKanbanNP"
                         data-pallets="@item.InventarioTemporal?.NumeroPallets"
                         data-razoninv="@item.InventarioTemporal?.RazonInventario"
                         data-fecha-inv="@item.InventarioTemporal?.FechaCompromiso?.ToString("yyyy-MM-dd")"
                         data-aplica-validacion="@item.InventarioTemporal?.AplicaValidacion"
                         data-aplica-responsable="@item.InventarioTemporal?.AplicaResponsable"
                         data-aplica-mandril="@item.InventarioTemporal?.AplicaMandril"
                         data-aplica-pallets="@item.InventarioTemporal?.AplicaPallets"
                         data-aplica-razon="@item.InventarioTemporal?.AplicaRazon"
                         data-aplica-fecha="@item.InventarioTemporal?.AplicaFecha">


                        <!-- Encabezado de la Tarjeta -->
                        <div class="card-header card-header-gradient border-bottom-0 pt-3 pb-2 d-flex justify-content-between align-items-center">
                            <span class="badge bg-light text-secondary border px-2.5 py-1.5 fw-semibold rounded-pill">
                                <i class="bi bi-geo-alt me-1 text-primary"></i>@(item.Area?.Nombre ?? "Sin Área")
                            </span>

                            @switch (item.Estatus)
                            {
                                case EstatusSolicitud.Pendiente:
                                    <span class="badge bg-warning text-dark px-2.5 py-1.5 fw-semibold rounded-pill">Pendiente</span>
                                    break;
                                case EstatusSolicitud.Aprobado:
                                case EstatusSolicitud.EnProceso:
                                    <span class="badge bg-info text-dark px-2.5 py-1.5 fw-semibold rounded-pill">En Proceso</span>
                                    break;
                                case EstatusSolicitud.Rechazado:
                                    <span class="badge bg-danger px-2.5 py-1.5 fw-semibold rounded-pill">Rechazada</span>
                                    break;
                                case EstatusSolicitud.Finalizado:
                                    <span class="badge bg-success px-2.5 py-1.5 fw-semibold rounded-pill">Finalizada</span>
                                    break;
                            }
                        </div>

                        <!-- Cuerpo de la Tarjeta -->
                        <div class="card-body py-2">
                            <h5 class="card-title fw-bold text-primary mb-3 d-flex align-items-center">
                                <i class="bi bi-arrow-right-circle me-2 fs-6"></i>@item.TipoMovimiento.ToString()
                            </h5>

                            <!-- Fila de Descripción en modo Carrusel/Truncado -->
                            <div class="mb-2">
                                <small class="text-uppercase text-muted fw-bold d-block" style="font-size: 0.65rem; letter-spacing: 0.5px;">Descripción</small>
                                <div class="marquee-container text-secondary small">
                                    <span class="marquee-text">@item.Descripcion</span>
                                </div>
                            </div>

                            <div class="divider-dashed"></div>

                            <!-- Fila de Justificación en modo Carrusel/Truncado -->
                            <div class="mb-2">
                                <small class="text-uppercase text-muted fw-bold d-block" style="font-size: 0.65rem; letter-spacing: 0.5px;">Justificación</small>
                                <div class="marquee-container text-muted small">
                                    <span class="marquee-text">@item.Razon</span>
                                </div>
                            </div>
                        </div>

                        <!-- Pie de la Tarjeta -->
                        <div class="card-footer card-footer-clean border-top-0 d-flex justify-content-between align-items-center py-2.5">
                            <small class="text-muted fw-medium small">
                                <i class="bi bi-calendar3 me-1 text-secondary"></i>@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                            </small>

                            <div class="prevent-modal-trigger d-flex gap-2 align-items-center">
                                @* BOTÓN: VER LAYOUT *@
                                @if (!string.IsNullOrEmpty(item.ImagenLayout))
                                {
                                    <a href="@item.ImagenLayout" target="_blank" class="btn btn-sm btn-outline-secondary px-2.5 py-1 fw-semibold d-inline-flex align-items-center rounded-pill" title="Ver croquis adjunto" onclick="event.stopPropagation();">
                                        <i class="bi bi-image me-1"></i>Ver Layout
                                    </a>
                                }
                                else
                                {
                                    <span class="badge bg-white text-muted border px-2.5 py-1.5 small fw-normal italic rounded-pill">
                                        Sin Layout
                                    </span>
                                }

                                @* BOTÓN: COMPLETAR INFO *@
                                @if (item.Estatus == EstatusSolicitud.EnProceso || item.Estatus == EstatusSolicitud.Aprobado)
                                {
                                    <a asp-action="CompletarInventario"
                                       asp-controller="Solicitudes"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-primary px-2.5 py-1 shadow-sm fw-semibold d-inline-flex align-items-center rounded-pill"
                                       onclick="event.stopPropagation();"
                                       title="Llenar datos de inventario y movimientos técnicos">
                                        <i class="bi bi-pencil-square me-1"></i>Completar Info
                                    </a>
                                }
                                @* BADGE: COMPLETADO *@
                                else if (item.Estatus == EstatusSolicitud.Finalizado)
                                {
                                    <span class="badge bg-light text-success border px-2.5 py-1.5 small fw-semibold d-inline-flex align-items-center rounded-pill" title="Información técnica registrada con éxito">
                                        <i class="bi bi-check-circle-fill me-1"></i>Completado
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- MODAL DE DETALLES DE LA SOLICITUD - DISEÑO REDISEÑADO -->
<div class="modal fade" id="modalDetalle" tabindex="-1" aria-labelledby="modalDetalleLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">

            <!-- Encabezado del Modal -->
            <div class="modal-header py-3 px-4 align-items-center">
                <h5 class="modal-title fw-bold text-secondary d-flex align-items-center mb-0" id="modalDetalleLabel">
                    <i class="bi bi-file-earmark-text me-2 text-primary fs-4"></i>Detalle de la Solicitud
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Cuerpo del Modal -->
            <div class="modal-body p-4">
                <div class="row g-4">

                    <!-- Fila de Metadatos Superiores (Distribución Flexible Antisolapamiento) -->
                    <div class="col-12 col-md-5">
                        <span class="modal-label-caps">Tipo de Movimiento</span>
                        <span id="modalTipo" class="fs-5 fw-bold text-primary d-block"></span>
                    </div>

                    <!-- col-md-auto hace que la columna mida exactamente lo que mida el texto de la sección -->
                    <div class="col-12 col-sm-6 col-md-auto flex-grow-1">
                        <span class="modal-label-caps">Área Asignada</span>
                        <span id="modalArea" class="badge bg-light text-dark border fs-6 px-3 py-1.5 rounded-pill fw-semibold text-nowrap d-inline-block"></span>
                    </div>

                    <div class="col-6 col-sm-6 col-md-auto">
                        <span class="modal-label-caps">Estatus Actual</span>
                        <span id="modalEstatus" class="badge fs-6 px-3 py-1.5 rounded-pill fw-semibold shadow-xs text-nowrap d-inline-block"></span>
                    </div>

                    <div class="col-12 my-1">
                        <hr class="text-muted opacity-25 m-0">
                    </div>

                    <!-- Descripción de la Solicitud -->
                    <div class="col-12">
                        <span class="modal-label-caps">Descripción Detallada</span>
                        <p id="modalDescripcion" class="content-panel-box border-start border-primary border-4 mb-0"></p>
                    </div>

                    <!-- Justificación / Razón -->
                    <div class="col-12">
                        <span class="modal-label-caps">Justificación / Razón de Petición</span>
                        <p id="modalRazon" class="content-panel-box mb-0"></p>
                    </div>

                    <!-- SECCIÓN DE INVENTARIO PREMIUM -->
                    <div id="seccionInventario" class="col-12 d-none">
                        <div class="my-2">
                            <hr class="text-muted opacity-25" />
                        </div>

                        <span class="modal-label-caps mb-3">
                            <i class="bi bi-boxes me-1.5 text-primary"></i>Información Técnica de Inventario
                        </span>

                        <!-- Caja contenedora principal -->
                        <div class="content-panel-box p-3 bg-light border-0">
                            <div class="inventory-grid">

                                <!-- 1. Validación -->
                                <div class="inventory-cell shadow-xs">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <span class="inventory-cell-title">Desviación</span>
                                        <!-- Este contenedor se llenará con JS: un badge verde con palomita o un badge gris N/A -->
                                        <span id="badgeValidacion"></span>
                                    </div>
                                    <span id="modalValidacion" class="inventory-cell-value text-secondary">—</span>
                                </div>

                                <!-- 2. Responsable -->
                                <div class="inventory-cell shadow-xs">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <span class="inventory-cell-title">Responsable</span>
                                        <span id="badgeResponsable"></span>
                                    </div>
                                    <span id="modalResponsable" class="inventory-cell-value text-secondary">—</span>
                                </div>

                                <!-- 3. Mandril / NP -->
                                <div class="inventory-cell shadow-xs">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <span class="inventory-cell-title">Mandriles/ Kanban / No. Parte </span>
                                        <span id="badgeMandril"></span>
                                    </div>
                                    <span id="modalMandril" class="inventory-cell-value text-secondary">—</span>
                                </div>

                                <!-- 4. Número de Pallets -->
                                <div class="inventory-cell shadow-xs">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <span class="inventory-cell-title">Cantidad Pallets</span>
                                        <span id="badgePallets"></span>
                                    </div>
                                    <span id="modalPallets" class="inventory-cell-value text-secondary">—</span>
                                </div>

                                <!-- 5. Razón de Inventario -->
                                <div class="inventory-cell shadow-xs">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <span class="inventory-cell-title">Razón de Inventario</span>
                                        <span id="badgeRazonInv"></span>
                                    </div>
                                    <span id="modalRazonInv" class="inventory-cell-value text-secondary">—</span>
                                </div>

                                <!-- 6. Fecha Compromiso -->
                                <div class="inventory-cell shadow-xs">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <span class="inventory-cell-title">Fecha Compromiso</span>
                                        <span id="badgeFechaInv"></span>
                                    </div>
                                    <span id="modalFechaInv" class="inventory-cell-value text-secondary">—</span>
                                </div>

                            </div>
                        </div>
                    </div>


                    <!-- Panel Informativo del Dictamen (Se muestra dinámicamente) -->
                    <div id="seccionRevision" class="col-12 d-none">
                        <div class="dictamen-card-info mt-1">
                            <h6 class="fw-bold text-primary mb-3 d-flex align-items-center" style="font-size: 0.9rem;">
                                <i class="bi bi-shield-check me-2 fs-5"></i>Información del Dictamen Técnico
                            </h6>
                            <div class="row g-3 small">
                                <div class="col-12 col-sm-6">
                                    <span class="text-muted d-block mb-0.5">Dictaminó:</span>
                                    <span id="modalAprobador" class="fw-bold text-dark fs-6"></span>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <span class="text-muted d-block mb-0.5">Fecha de Dictamen:</span>
                                    <span id="modalFechaRevision" class="fw-bold text-dark fs-6"></span>
                                </div>
                                <div class="col-12 mt-2">
                                    <span class="text-muted d-block mb-1 fw-medium">Comentarios del Revisor:</span>
                                    <p id="modalComentarios" class="mb-0 text-secondary bg-white p-2.5 rounded border border-light shadow-xs text-wrap"></p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Visualización del Croquis Adjunto -->
                    <div id="seccionCroquis" class="col-12 d-none">
                        <div class="my-1">
                            <hr class="text-muted opacity-25 m-0">
                        </div>
                        <span class="modal-label-caps text-start mb-2">Layout / Croquis Adjunto</span>
                        <div class="text-center bg-light p-2 rounded-3 border border-light">
                            <img id="modalImagen" src="" class="img-fluid rounded-3 shadow-sm img-preview-layout" alt="Layout de movimiento" />
                        </div>
                    </div>

                    <!-- Panel de Dictamen (Para Administradores en solicitudes Pendientes) -->
                    <div id="seccionFormularioRevision" class="col-12 d-none">
                        <div class="my-1">
                            <hr class="text-muted opacity-25 m-0">
                        </div>
                        <span class="modal-label-caps text-danger mb-2">Panel de Dictamen (Uso Administrativo)</span>
                        <textarea id="txtComentariosRevision" class="form-control textarea-dictamen" rows="2" placeholder="Escribe aquí de manera detallada los motivos de la aprobación o rechazo técnico..."></textarea>
                    </div>
                </div>
            </div>

            <!-- Pie del Modal con Botones de Acción -->
            <div class="modal-footer py-2.5 px-4">
                <small class="text-muted me-auto fw-medium d-flex align-items-center">
                    <i class="bi bi-clock me-1.5 text-secondary"></i>Creado el: <span id="modalFecha" class="ms-1 fw-bold"></span>
                </small>

                <!-- Botones de Control para Administradores -->
                <div id="bloqueAccionesAdmin" class="d-none">
                    <button type="button" id="btnRechazar" class="btn btn-outline-danger rounded-pill px-3.5 me-1 fw-semibold btn-sm shadow-xs">
                        <i class="bi bi-x-circle me-1.5"></i>Rechazar
                    </button>
                    <button type="button" id="btnAprobar" class="btn btn-success rounded-pill px-4 me-2 fw-semibold btn-sm shadow-sm">
                        <i class="bi bi-check-circle me-1.5"></i>Aprobar Movimiento
                    </button>
                </div>

                <button type="button" class="btn btn-secondary rounded-pill px-4 fw-semibold btn-sm shadow-xs" data-bs-dismiss="modal">Cerrar</button>
            </div>

        </div>
    </div>
</div>

<!-- LIGHTBOX -->
<div id="imageLightbox" style="
    display:none;
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.85);
    z-index:9999;
    justify-content:center;
    align-items:center;
">

    <!-- Botón cerrar -->
    <span style="
        position:absolute;
        top:20px;
        right:30px;
        color:white;
        font-size:30px;
        cursor:pointer;
        z-index:10000;
    " onclick="document.getElementById('imageLightbox').style.display='none'">
        ✕
    </span>

    <img id="lightboxImg" style="
        max-width:90%;
        max-height:90%;
        border-radius:10px;
        box-shadow:0 0 20px rgba(0,0,0,0.5);
    " />
</div>


@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const modalElement = document.getElementById('modalDetalle');
            const bsModal = new bootstrap.Modal(modalElement);

            // ✅ Lightbox elementos (una sola vez)
            const lightbox = document.getElementById('imageLightbox');
            const lightboxImg = document.getElementById('lightboxImg');

            let solicitudIdActual = null;

        document.querySelectorAll('.btn-detalle-solicitud').forEach(card => {
            card.addEventListener('click', function (event) {
                // Medida de seguridad: Evita abrir el modal si el usuario hizo clic en botones internos
                if (event.target.closest('.prevent-modal-trigger')) {
                    return;
                }

                // 🔹 Datos Generales
                solicitudIdActual = this.getAttribute('data-id');
                const area = this.getAttribute('data-area');
                const estatus = this.getAttribute('data-estatus');
                const tipo = this.getAttribute('data-tipo');
                const descripcion = this.getAttribute('data-descripcion');
                const razon = this.getAttribute('data-razon');
                const fecha = this.getAttribute('data-fecha');
                const imagen = this.getAttribute('data-imagen');
                const aprobador = this.getAttribute('data-aprobador');
                const fechaRevision = this.getAttribute('data-fecharevision');
                const comentarios = this.getAttribute('data-comentarios');

                // Banderas de validación (Evaluando 'True' proveniente del backend de C#)
                const aplicaValidacion = this.getAttribute('data-aplica-validacion') === 'True';
                const aplicaResponsable = this.getAttribute('data-aplica-responsable') === 'True';
                const aplicaMandril = this.getAttribute('data-aplica-mandril') === 'True';
                const aplicaPallets = this.getAttribute('data-aplica-pallets') === 'True';
                const aplicaRazon = this.getAttribute('data-aplica-razon') === 'True';
                const aplicaFecha = this.getAttribute('data-aplica-fecha') === 'True';

                // Valores textuales
                const validacion = this.getAttribute('data-validacion');
                const responsable = this.getAttribute('data-responsable');
                const mandril = this.getAttribute('data-mandril');
                const pallets = this.getAttribute('data-pallets');
                const razonInv = this.getAttribute('data-razoninv');
                const fechaInv = this.getAttribute('data-fecha-inv');

                // ==================================================================
                // 🔹 RENDERIZADO PREMIUM DE INVENTARIO (CON PALOMITAS / N/A)
                // ==================================================================
                const seccionInventario = document.getElementById('seccionInventario');

                // El bloque se muestra si la solicitud está EnProceso o Finalizada (y existen datos técnicos creados o mapeados)
                if (estatus === "EnProceso" || estatus === "Finalizado" || validacion || responsable || mandril || pallets || razonInv || fechaInv) {

                    // Función auxiliar interna para inyectar las palomitas y formatear los textos correspondientes
                    function procesarCeldaTecnica(idBadge, idTexto, aplica, valorReal) {
                        const elBadge = document.getElementById(idBadge);
                        const elTexto = document.getElementById(idTexto);

                        if (aplica) {
                            elBadge.innerHTML = '<span class="badge bg-success-subtle text-success rounded-pill px-2 py-0.5 small shadow-xs"><i class="bi bi-check-lg"></i></span>';
                            elTexto.innerText = (valorReal && valorReal !== "null" && valorReal !== "") ? valorReal : "Sin especificar";
                            elTexto.classList.remove("text-muted", "fst-italic");
                        } else {
                            elBadge.innerHTML = '<span class="badge bg-light text-muted border rounded-pill px-2 py-0.5 small">N/A</span>';
                            elTexto.innerText = "No aplica";
                            elTexto.classList.add("text-muted", "fst-italic");
                        }
                    }

                    // Procesamos las 6 celdas técnicas de forma simétrica
                    procesarCeldaTecnica("badgeValidacion", "modalValidacion", aplicaValidacion, validacion);
                    procesarCeldaTecnica("badgeResponsable", "modalResponsable", aplicaResponsable, responsable);
                    procesarCeldaTecnica("badgeMandril", "modalMandril", aplicaMandril, mandril);
                    procesarCeldaTecnica("badgePallets", "modalPallets", aplicaPallets, pallets);
                    procesarCeldaTecnica("badgeRazonInv", "modalRazonInv", aplicaRazon, razonInv);
                    procesarCeldaTecnica("badgeFechaInv", "modalFechaInv", aplicaFecha, fechaInv);

                    seccionInventario.classList.remove('d-none');
                } else {
                    seccionInventario.classList.add('d-none');
                }

                // 🔹 Inyección del Contenido Base
                document.getElementById('modalTipo').innerText = tipo;
                document.getElementById('modalArea').innerText = area;
                document.getElementById('modalDescripcion').innerText = descripcion;
                document.getElementById('modalRazon').innerText = razon;
                document.getElementById('modalFecha').innerText = fecha;

                // ==================================================================
                // 🔹 CONTROL MÁQUINA DE ESTADOS (BADGES, PANELES ADMIN Y REVISIÓN)
                // ==================================================================
                const badge = document.getElementById('modalEstatus');
                const seccionRevision = document.getElementById('seccionRevision');
                const bloqueAdmin = document.getElementById('bloqueAccionesAdmin');
                const formRevision = document.getElementById('seccionFormularioRevision');

                // Mapeo correcto de nombres estéticos y reseteo de clases base
                badge.innerText = estatus === "EnProceso" ? "En Proceso" : estatus === "Finalizado" ? "Finalizada" : estatus;
                badge.className = "badge fs-6 px-3 py-1.5 rounded-pill fw-semibold shadow-xs text-nowrap d-inline-block";

                if (estatus === "Pendiente") {
                    // Estatus visual
                    badge.classList.add("bg-warning", "text-dark");

                    // Paneles activos (Uso administrativo para dictamen)
                    bloqueAdmin.classList.remove('d-none');
                    formRevision.classList.remove('d-none');
                    document.getElementById('txtComentariosRevision').value = '';

                    // Paneles ocultos
                    seccionRevision.classList.add('d-none');
                }
                else {
                    // Asignación de colores según los nuevos estados avanzados o rechazo
                    if (estatus === "EnProceso" || estatus === "Aprobado") {
                        badge.classList.add("bg-info", "text-dark");
                    } else if (estatus === "Finalizado") {
                        badge.classList.add("bg-success", "text-white");
                    } else {
                        badge.classList.add("bg-danger", "text-white");
                    }

                    // Renderizado de datos del dictamen histórico realizado
                    document.getElementById('modalAprobador').innerText = aprobador;
                    document.getElementById('modalFechaRevision').innerText = fechaRevision;
                    document.getElementById('modalComentarios').innerText = comentarios;

                    // Paneles activos / ocultos correspondientes
                    seccionRevision.classList.remove('d-none');
                    bloqueAdmin.classList.add('d-none');
                    formRevision.classList.add('d-none');
                }

                // ==================================================================
                // 🔹 GESTIÓN DEL CROQUIS / LAYOUT ADJUNTO
                // ==================================================================
                const seccionCroquis = document.getElementById('seccionCroquis');
                const modalImagen = document.getElementById('modalImagen');

                if (imagen && imagen.trim() !== "") {
                    modalImagen.src = imagen;

                    // Transfiere la imagen seleccionada al Lightbox global
                    modalImagen.onclick = function (e) {
                        e.stopPropagation();
                        lightbox.style.display = "flex";
                        lightboxImg.src = this.src;
                    };

                    seccionCroquis.classList.remove('d-none');
                } else {
                    seccionCroquis.classList.add('d-none');
                }

                // 10. Despliegue en pantalla del modal
                bsModal.show();
            });
        });


            // ✅ cerrar lightbox
            lightbox.onclick = function () {
                lightbox.style.display = "none";
            };

            // 🔹 enviar dictamen
            async function enviarDictamen(nuevoEstatus) {

                const comentarios = document.getElementById('txtComentariosRevision').value;

                let estatusId = 0;
                if (nuevoEstatus === 'Aprobado') estatusId = 1;
                if (nuevoEstatus === 'Rechazado') estatusId = 2;

                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                const formData = new FormData();
                formData.append("id", solicitudIdActual);
                formData.append("nuevoEstatus", estatusId);
                formData.append("comentarios", comentarios);

                if (token) {
                    formData.append("__RequestVerificationToken", token);
                }

                try {
                    const response = await fetch('/Solicitudes/Evaluar', {
                        method: 'POST',
                        body: formData
                    });

                    if (!response.ok) {
                        throw new Error("Error servidor");
                    }

                    const result = await response.json();

                    if (result.success) {

                        if (result.redirectUrl) {
                            window.location.href = result.redirectUrl; 
                            return;
                        }

                        bsModal.hide();
                        window.location.reload();
                    }else {
                        alert(result.message);
                    }
                } catch (err) {
                    alert("Error procesando solicitud");
                    console.error(err);
                }
            }

            // ✅ botones
            document.getElementById('btnAprobar').addEventListener('click', () => enviarDictamen('Aprobado'));
            document.getElementById('btnRechazar').addEventListener('click', () => enviarDictamen('Rechazado'));

        });
    </script>
}

