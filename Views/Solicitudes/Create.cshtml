@model Layout.Models.ViewModels.SolicitudCreateViewModel

@{
    ViewData["Title"] = "Nueva Solicitud";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-8 col-md-10">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white p-3">
                <h3 class="card-title mb-0 h5"><i class="bi bi-file-earmark-plus me-2"></i>Nueva Solicitud de Movimiento</h3>
            </div>
            <div class="card-body p-4">

                <!-- Contenedor dinámico para alertas globales de Fetch -->
                <div id="alertContainer"></div>

                <form id="formSolicitud" asp-action="Create" method="post" enctype="multipart/form-data" novalidate>

                    <!-- Token Antiforgery oculto automático de ASP.NET Core -->
                    @Html.AntiForgeryToken()

                    <div class="row">
                        <!-- Área -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="AreaId" class="form-label fw-bold small text-secondary">Área</label>
                            <select asp-for="AreaId" asp-items="Model.Areas" class="form-select form-control-modern" required>
                                <option value="">Seleccione un área...</option>
                            </select>
                            <span asp-validation-for="AreaId" class="text-danger small"></span>
                        </div>

                        <!-- Tipo Movimiento -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="TipoMovimiento" class="form-label fw-bold small text-secondary">Tipo de Movimiento</label>
                            <select asp-for="TipoMovimiento" class="form-select form-control-modern"
                                    asp-items="Html.GetEnumSelectList<Layout.Models.Enums.TipoMovimiento>()" required>
                            </select>
                            <span asp-validation-for="TipoMovimiento" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Razón -->
                    <div class="mb-3">
                        <label asp-for="Razon" class="form-label fw-bold small text-secondary">Motivos para solicitar el movimiento de Layout:</></label>
                        <textarea asp-for="Razon" class="form-control form-control-modern" rows="3" placeholder="¿Por qué se requiere este movimiento?"></textarea>
                        <span asp-validation-for="Razon" class="text-danger small"></span>
                    </div>

                    <!-- Descripción -->
                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label fw-bold small text-secondary">Detallar el movimiento requerido:</label>
                        <textarea asp-for="Descripcion" class="form-control form-control-modern" rows="3" placeholder="Detalla brevemente la solicitud..."></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger small"></span>
                    </div>

                    <!-- Imagen -->
                    <small class="bg-danger-subtle text-danger fw-bold">En revision</small>
                    <div class="mb-4 border-3 border-dark border" disabled>
                       
                        <label asp-for="Imagen" class="form-label fw-bold small text-secondary" >Dibujo o Croquis (Imagen)</label>
                        <input  type="file" asp-for="Imagen" class="form-control form-control-modern" accept="image/*" />
                        <div class="form-text small">Archivos sugeridos: PNG, JPG, JPEG.</div>
                        <span asp-validation-for="Imagen" class="text-danger small"></span>
                    </div>
                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label asp-for="FechaInicioMovimiento" class="fw-semibold">
                                Fecha a partir de
                            </label>

                            <input asp-for="FechaInicioMovimiento"
                                   type="date"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="FechaFinMovimiento" class="fw-semibold">
                                Fecha de terminación
                            </label>

                            <input asp-for="FechaFinMovimiento"
                                   type="date"
                                   class="form-control" />
                        </div>

                    </div>


                    <hr class="mt-4" />

                    <h5 class="text-primary fw-bold mb-3">
                        <i class="bi bi-box-seam me-2"></i>Información de Inventario
                    </h5>

                    <!-- VALIDACION -->
                    <div class="mb-3">
                        <input type="checkbox" id="chkValidacion" asp-for="AplicaValidacion" />
                        <label class="fw-semibold">Número de Validación</label>
                        <input id="txtValidacion" asp-for="NumeroValidacion" class="form-control" readonly />
                    </div>

                    <!-- RESPONSABLE -->
                    <div class="mb-3">
                        <input type="checkbox" id="chkResponsable" asp-for="AplicaResponsable" />
                        <label class="fw-semibold">Responsable Inventario</label>
                        <input id="txtResponsable" asp-for="ResponsableInventario" class="form-control" readonly />
                    </div>

                    <!-- MANDRIL -->
                    <div class="mb-3">
                        <input type="checkbox" id="chkMandril" asp-for="AplicaMandril" />
                        <label class="fw-semibold">Mandril / Kanban / NP</label>
                        <input id="txtMandril" asp-for="MandrilKanbanNP" class="form-control" readonly />
                    </div>

                    <!-- PALLETS -->
                    <div class="mb-3">
                        <input type="checkbox" id="chkPallets" asp-for="AplicaPallets" />
                        <label class="fw-semibold"># Pallets</label>
                        <input id="txtPallets" asp-for="NumeroPallets" class="form-control" readonly />
                    </div>

                    <!-- RAZON INVENTARIO -->
                    <div class="mb-3">
                        <input type="checkbox" id="chkRazonInv" asp-for="AplicaRazonInventario" />
                        <label class="fw-semibold">Razón Inventario</label>
                        <textarea id="txtRazonInv" asp-for="RazonInventario" class="form-control" readonly></textarea>
                    </div>

                  
                    <!-- Botones -->
                    <div class="d-flex justify-content-end gap-2 border-top pt-3">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-light px-4">Cancelar</a>
                        <button type="submit" id="btnGuardar" class="btn btn-primary px-4">
                            <span id="btnText">Guardar Solicitud</span>
                            <span id="btnSpinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function toggleInput(checkId, inputId) {
            const chk = document.getElementById(checkId);
            const input = document.getElementById(inputId);

            if (!chk || !input) return;

            input.readOnly = !chk.checked;

            chk.addEventListener("change", function () {
                input.readOnly = !this.checked;

                if (!this.checked) {
                    input.value = "";
                }
            });
        }

        // Inicialización
        toggleInput("chkValidacion", "txtValidacion");
        toggleInput("chkResponsable", "txtResponsable");
        toggleInput("chkMandril", "txtMandril");
        toggleInput("chkPallets", "txtPallets");
        toggleInput("chkRazonInv", "txtRazonInv");
        toggleInput("chkFecha", "txtFecha");
        document.getElementById('formSolicitud').addEventListener('submit', async function (e) {
            e.preventDefault(); // Evitamos que la página recargue de forma tradicional

            const form = this;
            const btnGuardar = document.getElementById('btnGuardar');
            const btnText = document.getElementById('btnText');
            const btnSpinner = document.getElementById('btnSpinner');
            const alertContainer = document.getElementById('alertContainer');

            // Limpiar alertas previas
            alertContainer.innerHTML = '';
                    // ====================================
        // VALIDACIONES CONDICIONALES INVENTARIO
        // ====================================

        const errores = [];

        if ($("#chkValidacion").is(":checked") &&
            !$("#txtValidacion").val().trim()) {
            errores.push("Debe capturar el Número de Validación.");
        }

        if ($("#chkResponsable").is(":checked") &&
            !$("#txtResponsable").val().trim()) {
            errores.push("Debe capturar el Responsable de Inventario.");
        }

        if ($("#chkMandril").is(":checked") &&
            !$("#txtMandril").val().trim()) {
            errores.push("Debe capturar Mandril / Kanban / NP.");
        }

        if ($("#chkPallets").is(":checked") &&
            !$("#txtPallets").val().trim()) {
            errores.push("Debe capturar el número de pallets.");
        }

        if ($("#chkRazonInv").is(":checked") &&
            !$("#txtRazonInv").val().trim()) {
            errores.push("Debe capturar la Razón de Inventario.");
        }

        if (errores.length > 0) {

            let html = `
                <div class="alert alert-danger">
                    <strong>Favor de completar la información requerida:</strong>
                    <ul class="mb-0 mt-2">
            `;

            errores.forEach(e => {
                html += `<li>${e}</li>`;
            });

            html += `
                    </ul>
                </div>
            `;

            alertContainer.innerHTML = html;

            return false;
        }
            // Forzar gatillo de validación nativa de jQuery Validation de ASP.NET Core
            if (!$(form).valid()) {
                return false;
            }

            // Deshabilitar botón y activar spinner de carga
            btnGuardar.disabled = true;
            btnText.innerText = "Procesando...";
            btnSpinner.classList.remove('d-none');

            // Recopilar los datos del formulario (Automáticamente añade archivos/imágenes del input type="file")
            const formData = new FormData(form);

            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        // El RequestVerificationToken se añade solo gracias a FormData si el form tiene el Tag Helper
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (!response.ok) {
                    throw new Error('Error en la comunicación con el servidor.');
                }

                const result = await response.json();

                if (result.success) {
                    // Mostrar alerta de éxito
                    alertContainer.innerHTML = `
                        <div class="alert alert-success d-flex align-items-center" role="alert">
                            <div>${result.message}. Redireccionando...</div>
                        </div>`;

                    // Esperar 1.5 segundos para que el usuario lea el éxito y luego redirigir
                    setTimeout(() => {
                        window.location.href = result.redirectUrl;
                    }, 1500);

                } else {
                    // Si el servidor retornó un fallo controlado (ej: Validación fallida)
                    let errorHtml = `<div class="alert alert-danger" role="alert"><strong>${result.message}</strong>`;
                    if (result.errors && result.errors.length > 0) {
                        errorHtml += '<ul class="mb-0 mt-2">';
                        result.errors.forEach(err => errorHtml += `<li>${err}</li>`);
                        errorHtml += '</ul>';
                    }
                    errorHtml += '</div>';

                    alertContainer.innerHTML = errorHtml;

                    // Reactivar botón si hubo fallos de negocio
                    btnGuardar.disabled = false;
                    btnText.innerText = "Guardar Solicitud";
                    // ✅ CORREGIDO: Se cambió .addClass por .classList.add
                    btnSpinner.classList.add('d-none');
                }

            } catch (error) {
                // Errores graves (caída de red, código de servidor roto, etc.)
                alertContainer.innerHTML = `
                    <div class="alert alert-danger" role="alert">
                        <strong>Error:</strong> No se pudo procesar la solicitud en este momento. (${error.message})
                    </div>`;

                btnGuardar.disabled = false;
                btnText.innerText = "Guardar Solicitud";
                // ✅ Aquí ya estaba bien, por lo que todo funcionará correctamente
                btnSpinner.classList.add('d-none');
            }
        });
    </script>
}
